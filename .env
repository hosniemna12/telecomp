# .env.docker - Example configuration for Docker
# Copy this to .env and modify as needed

APP_NAME=TeleCompensation
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

APP_KEY=base64:vPbikgCBJkjsUYOBouNjECPwf3HX/aW6cpE2RUIzmF8=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=telecompensation
DB_USERNAME=telecompensation
DB_PASSWORD=secret

# Redis Configuration
REDIS_HOST=redis
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# Cache & Session
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Additional services
ORACLE_HOST=oracle
ORACLE_PORT=1521
ORACLE_DATABASE=XE
ORACLE_USERNAME=system
ORACLE_PASSWORD=oracle
